{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "processes": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "description": "A unique name for the item"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "cmd": {
            "type": "string",
            "description": "The command to execute"
          },
          "args": {
            "description": "Arguments to pass to the command",
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "restart": {
            "description": "Whether to restart the process if it exits (default: true)",
            "default": true,
            "type": "boolean"
          },
          "unique": {
            "description": "Whether only one instance of the job can run at a time",
            "default": true,
            "type": "boolean"
          },
          "logs": {
            "type": "object",
            "properties": {
              "stdout": {
                "type": "string",
                "description": "Path to the standard output log file"
              },
              "stderr": {
                "type": "string",
                "description": "Path to the standard error log file"
              }
            },
            "required": [
              "stdout",
              "stderr"
            ],
            "additionalProperties": false,
            "description": "Log file paths for the job"
          }
        },
        "required": [
          "cmd",
          "logs"
        ],
        "additionalProperties": false
      },
      "description": "Processes to run continuously"
    },
    "tasks": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "description": "A unique name for the item"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "cmd": {
            "type": "string",
            "description": "The command to execute"
          },
          "args": {
            "description": "Arguments to pass to the command",
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "restart": {
            "description": "Whether to restart the task if it exits (default: false)",
            "default": false,
            "type": "boolean"
          },
          "unique": {
            "description": "Whether only one instance of the job can run at a time",
            "default": true,
            "type": "boolean"
          },
          "logs": {
            "type": "object",
            "properties": {
              "stdout": {
                "type": "string",
                "description": "Path to the standard output log file"
              },
              "stderr": {
                "type": "string",
                "description": "Path to the standard error log file"
              }
            },
            "required": [
              "stdout",
              "stderr"
            ],
            "additionalProperties": false,
            "description": "Log file paths for the job"
          }
        },
        "required": [
          "cmd",
          "logs"
        ],
        "additionalProperties": false
      },
      "description": "One-off tasks to run"
    },
    "schedules": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "description": "A unique name for the item"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "cron": {
            "type": "string",
            "description": "Cron expression for scheduling"
          },
          "task": {
            "type": "string",
            "minLength": 1,
            "description": "Name of the task to run"
          }
        },
        "required": [
          "cron",
          "task"
        ],
        "additionalProperties": false
      },
      "description": "Scheduled tasks"
    }
  },
  "additionalProperties": false
}