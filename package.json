{
  "name": "@ludovicm67/scheduler",
  "version": "0.2.2",
  "description": "A simple Node.js based tasks and services scheduler",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "cli": "./dist/index.js"
  },
  "scripts": {
    "start": "node src/index.ts",
    "knip": "knip",
    "build": "rm -rf dist && tsc && npm run update-schema && vite build && chmod +x dist/index.js && npm run fix-types",
    "prepack": "npm run build",
    "update-schema": "node src/scripts/update-schema.ts",
    "fix-types": "node src/scripts/fix-types.ts",
    "release": "changeset publish",
    "test": "node --experimental-strip-types --test tests/*.test.ts"
  },
  "keywords": [
    "scheduler"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludovicm67/node-scheduler.git"
  },
  "author": {
    "name": "Ludovic Muller",
    "url": "https://ludovic-muller.fr/"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^15.0.0",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^14.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/express": "^5.0.6",
    "knip": "^6.13.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-static-copy": "^4.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
