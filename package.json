{
  "name": "@ludovicm67/scheduler",
  "version": "0.2.1",
  "description": "A simple Node.js based tasks and services scheduler",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "cli": "./dist/index.js"
  },
  "scripts": {
    "start": "node src/index.ts",
    "knip": "knip",
    "build": "rm -rf dist && tsc && npm run update-schema && vite build && chmod +x dist/index.js && npm run fix-types",
    "prepack": "npm run build",
    "update-schema": "node src/scripts/update-schema.ts",
    "fix-types": "node src/scripts/fix-types.ts",
    "release": "changeset publish",
    "test": "node --experimental-strip-types --test tests/*.test.ts"
  },
  "keywords": [
    "scheduler"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludovicm67/node-scheduler.git"
  },
  "author": {
    "name": "Ludovic Muller",
    "url": "https://ludovic-muller.fr/"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^14.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/express": "^5.0.6",
    "knip": "^6.6.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-static-copy": "^4.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
